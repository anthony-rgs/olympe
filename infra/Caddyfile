# Serve HTTPS for the API domain and proxy to the FastAPI service in Docker

# Hermes - API de récupération des données Spotify billions club

hermes.olympe.center {
encode zstd gzip # Enable compression
reverse_proxy olympe-hermes:8000 # Forward to the 'hermes' container's port 8000
}

# Orphée — API de génération de vidéos musicales

orphee.olympe.center {
encode zstd gzip # Enable compression
reverse_proxy olympe-orphee:8000 # Forward to the 'orphee' container's port 8000
}

# Redirections

artemis-code.olympe.center {
